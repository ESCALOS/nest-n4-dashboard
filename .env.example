# PostgreSQL - Prisma (for user authentication)
DATABASE_URL=postgresql://user:password@localhost:5432/myfirstapp

# SQL Server - N4 Terminal Database
N4_DB_HOST=n4-server-host
N4_DB_PORT=1433
N4_DB_USER=n4_user
N4_DB_PASSWORD=n4_password
N4_DB_NAME=n4_database

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Background Job Intervals (in milliseconds)
SHIPPING_REFRESH_INTERVAL=15000
APPOINTMENTS_REFRESH_INTERVAL=5000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=3600
